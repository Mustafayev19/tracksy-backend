{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    // DÜZƏLİŞ: Aşağıdakı konfiqurasiyalar əlavə edildi
    "paths": {
      // Bu, '@prisma/client' paketinin daxilindəki modelləri tapmaq üçündür
      "@prisma/client": ["./node_modules/.prisma/client"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/.prisma/client" // DÜZƏLİŞ: Prisma tiplərini tanımak üçün
    ]
  }
}
